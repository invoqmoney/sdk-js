{
  "name": "sdk-js",
  "version": "0.1.0",
  "description": "Workspace for the invoq JavaScript SDK packages.",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/invoqmoney/sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/invoqmoney/sdk-js/issues"
  },
  "homepage": "https://github.com/invoqmoney/sdk-js#readme",
  "type": "module",
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "test": "pnpm -r --filter './packages/*' test",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.43",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
