{
  "name": "@invoq/server",
  "version": "0.1.0",
  "description": "Node.js SDK for invoq server APIs and webhook verification.",
  "keywords": [
    "invoq",
    "stablecoin",
    "stablecoin-payments",
    "payments",
    "crypto-payments",
    "usdc",
    "usdt",
    "checkout",
    "invoices",
    "webhooks",
    "node",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/invoqmoney/sdk-js.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/invoqmoney/sdk-js/issues"
  },
  "homepage": "https://github.com/invoqmoney/sdk-js/tree/main/packages/server#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "tsdown": {
    "format": [
      "esm",
      "cjs"
    ]
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "pnpm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
